{
  "name": "plank-board",
  "version": "0.1.0",
  "description": "마크다운 기반 칸반 보드 태스크 관리 도구 — AI CLI 연동 지원",
  "type": "module",
  "bin": {
    "plank-board": "bin/plank.js"
  },
  "files": [
    "bin/",
    "server/",
    "dist/",
    "CLAUDE.md",
    ".claude/",
    "README.md"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "prepublishOnly": "npm run build",
    "release:patch": "npm version patch && npm publish && git push origin develop --tags",
    "release:minor": "npm version minor && npm publish && git push origin develop --tags",
    "release:major": "npm version major && npm publish && git push origin develop --tags"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "gray-matter": "^4.0.3",
    "chokidar": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "vite": "^6.0.0"
  }
}
